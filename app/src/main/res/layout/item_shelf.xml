<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_surface_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvShelfTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shelf Title"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvShelfDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Shelf description"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_chip"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="Shelf Visibility Status Here"
        android:textColor="@color/brand"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvShelfCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="0 books"
        android:textColor="@color/brand"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
