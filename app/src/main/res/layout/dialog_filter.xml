<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sort_by"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rgSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbRatingHighLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rating_high_to_low" />

        <RadioButton
            android:id="@+id/rbRatingLowHigh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rating_low_to_high" />

        <RadioButton
            android:id="@+id/rbDateNewest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/date_newest_to_oldest" />

        <RadioButton
            android:id="@+id/rbDateOldest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/date_oldest_to_newest" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_by_category"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnCategory"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/all_categories"
        android:gravity="start|center_vertical" />

</LinearLayout>
