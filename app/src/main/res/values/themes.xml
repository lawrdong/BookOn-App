<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.BookOn" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- (possibly temporary) Disable activity animations -->
        <item name="android:windowAnimationStyle">@style/Animation_None</item>
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
    </style>

    <style name="Theme.BookOn" parent="Base.Theme.BookOn" />

    <!-- No animation style -->
    <style name="Animation_None">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
    </style>

</resources>
